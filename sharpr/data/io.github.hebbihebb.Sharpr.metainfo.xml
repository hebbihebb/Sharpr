<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.hebbihebb.Sharpr</id>
  <name>Sharpr</name>
  <summary>A modern image library and viewer</summary>
  <description>
    <p>
      Sharpr is a fast, modern image library and viewer for Linux.
      Browse large photo collections with a three-pane interface,
      inspect detailed metadata, and upscale images using AI — all offline and locally.
    </p>
  </description>
  <url type="homepage">https://github.com/hebbihebb/Sharpr</url>
  <url type="bugtracker">https://github.com/hebbihebb/Sharpr/issues</url>
  <url type="vcs-browser">https://github.com/hebbihebb/Sharpr</url>
  <launchable type="desktop-id">io.github.hebbihebb.Sharpr.desktop</launchable>
  <screenshots>
    <screenshot type="default">
      <caption>Three-pane image browser showing the photo library, filmstrip, and metadata overlay.</caption>
      <image>https://raw.githubusercontent.com/hebbihebb/Sharpr/main/DesignDocs/UI%20design%20draft_v2.png</image>
    </screenshot>
  </screenshots>
  <releases>
    <release version="0.1.0" date="2026-04-04">
      <description>
        <p>Initial MVP release: three-pane adaptive UI, thumbnail filmstrip, image preview, metadata overlay.</p>
      </description>
    </release>
  </releases>
  <content_rating type="oars-1.1"/>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <developer_name>Sharpr Contributors</developer_name>
  <developer id="io.github.hebbihebb.Sharpr">
    <name>Sharpr Contributors</name>
  </developer>
  <provides>
    <binary>sharpr</binary>
  </provides>
  <categories>
    <category>Graphics</category>
    <category>Viewer</category>
  </categories>
  <keywords>
    <keyword>image</keyword>
    <keyword>viewer</keyword>
    <keyword>photo</keyword>
    <keyword>gallery</keyword>
    <keyword>upscale</keyword>
  </keywords>
  <requires>
    <display_length compare="ge">768</display_length>
  </requires>
  <recommends>
    <control>keyboard</control>
    <control>pointing</control>
  </recommends>
</component>
