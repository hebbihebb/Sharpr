[Desktop Entry]
Name=Sharpr
GenericName=Image Viewer
Comment=Browse and view your photo library
Exec=sharpr %F
Icon=io.github.hebbihebb.Sharpr
Terminal=false
Type=Application
Categories=Graphics;Viewer;GNOME;GTK;
MimeType=image/jpeg;image/png;image/gif;image/webp;image/tiff;image/bmp;
StartupWMClass=sharpr
X-GNOME-UsesNotifications=false
