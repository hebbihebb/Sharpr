<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="io.github.hebbihebb.Sharpr" path="/io/github/hebbihebb/Sharpr/">
    <key name="last-folder" type="s">
      <default>""</default>
      <summary>Last opened folder</summary>
      <description>The path of the folder last opened by the user.</description>
    </key>
    <key name="metadata-visible" type="b">
      <default>true</default>
      <summary>Metadata overlay visible</summary>
      <description>Whether the floating metadata overlay is shown in the viewer.</description>
    </key>
    <key name="library-root" type="s">
      <default>""</default>
      <summary>Custom library root folder</summary>
      <description>If set, sidebar scans this path instead of ~/Pictures.</description>
    </key>
    <key name="upscaler-binary-path" type="s">
      <default>""</default>
      <summary>Custom realesrgan-ncnn-vulkan binary path</summary>
      <description>Override the auto-detected binary location.</description>
    </key>
    <key name="upscaler-default-model" type="s">
      <default>"standard"</default>
      <summary>Default upscale model</summary>
      <description>Either "standard" or "anime".</description>
    </key>
    <key name="thumbnail-cache-max" type="i">
      <default>500</default>
      <summary>Thumbnail memory cache size</summary>
      <description>Maximum number of thumbnails to hold in memory.</description>
    </key>
    <key name="window-width" type="i">
      <default>1400</default>
      <summary>Window width</summary>
    </key>
    <key name="window-height" type="i">
      <default>900</default>
      <summary>Window height</summary>
    </key>
  </schema>
</schemalist>
